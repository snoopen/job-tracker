{
  "name": "job-tracker",
  "version": "1.0.0",
  "description": "A personal job application tracking tool",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "keywords": [],
  "author": "Scott Picton",
  "license": "MIT",
  "scripts": {
    "lint": "npm run lint --workspaces --if-present",
    "prepare": "husky"
  },
  "devDependencies": {
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0"
  },
  "lint-staged": {
    "**/*.{ts,tsx}": ["eslint --flag unstable_config_lookup_from_file --fix", "prettier --write"]
  }
}
